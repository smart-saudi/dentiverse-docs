%% DentiVerse — System Architecture Diagram
%% Shows how all infrastructure components connect.

flowchart TD
    subgraph Clients["Client Tier"]
        WEB["Web App\n(Next.js 15)"]
        MOB["Mobile\n(Future)"]
        VIEWER["3D Viewer\n(Three.js)"]
        ADMIN["Admin\nPanel"]
    end

    subgraph Edge["Edge Tier"]
        CF["Cloudflare\nCDN + DDoS + SSL"]
    end

    subgraph App["Application Tier — Vercel"]
        SSR["Next.js SSR\nAPI Routes"]
    end

    subgraph Backend["Backend Tier — Supabase"]
        AUTH["Supabase Auth\nJWT, OAuth, RLS"]
        EDGE["Edge Functions\nMatching, Validation"]
        RT["Supabase Realtime\nWebSocket Events"]
    end

    subgraph Data["Data Tier"]
        PG["PostgreSQL 16\nRLS, Full-text Search"]
        STORAGE["Supabase Storage\nScans, Designs, Files"]
    end

    subgraph External["External Services"]
        STRIPE["Stripe Connect\nEscrow, Payouts"]
        EMAIL["Resend\nTransactional Email"]
        SENTRY["Sentry\nError Monitoring"]
    end

    WEB --> CF
    MOB --> CF
    VIEWER --> CF
    ADMIN --> CF
    CF --> SSR
    SSR --> AUTH
    SSR --> EDGE
    SSR --> STRIPE
    AUTH --> PG
    EDGE --> PG
    EDGE --> STORAGE
    RT --> PG
    SSR --> EMAIL
    SSR --> SENTRY
    STRIPE -.->|"Webhooks"| SSR

    style Clients fill:#E6F1FB,stroke:#185FA5
    style Edge fill:#F1EFE8,stroke:#5F5E5A
    style App fill:#E1F5EE,stroke:#0F6E56
    style Backend fill:#EEEDFE,stroke:#534AB7
    style Data fill:#FAEEDA,stroke:#854F0B
    style External fill:#FAECE7,stroke:#993C1D
